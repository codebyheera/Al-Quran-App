{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.alquranhub.org"
        }
      ],
      "destination": "https://alquranhub.org/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/surah/:name",
      "destination": "/surah/:name/index.html"
    },
    {
      "source": "/juz/:num",
      "destination": "/juz/:num/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}