{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.alquranhub.org"
        }
      ],
      "destination": "https://alquranhub.org/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/surah/:name",
      "destination": "/surah/:name/index.html"
    },
    {
      "source": "/juz/:num",
      "destination": "/juz/:num/index.html"
    },
    {
      "source": "/surah",
      "destination": "/surah/index.html"
    },
    {
      "source": "/juz",
      "destination": "/juz/index.html"
    },
    {
      "source": "/bookmarks",
      "destination": "/bookmarks/index.html"
    },
    {
      "source": "/tasbih",
      "destination": "/tasbih/index.html"
    },
    {
      "source": "/search",
      "destination": "/search/index.html"
    },
    {
      "source": "/support",
      "destination": "/support/index.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}